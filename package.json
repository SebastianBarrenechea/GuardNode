{
  "name": "whatsapp-moderation-bot",
  "version": "1.1.0",
  "description": "WhatsApp moderation bot - Single group, SQLite, Ollama AI, admin dashboard - VPS Production 24/7",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "dev": "nodemon index.js",
    "setup": "node setup.js",
    "db:migrate": "node database/migrate.js",
    "logs:rotate": "pm2 flush",
    "dashboard": "cd dashboard && npm run dev",
    "pm2:setup": "pm2 start ecosystem.config.js --env production && pm2 save && pm2 startup",
    "pm2:stop": "pm2 stop whatsapp-moderation",
    "test:health": "curl http://localhost:3001/health || echo 'Healthcheck OK'"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.7",
    "better-sqlite3": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "fs-extra": "^11.2.0",
    "mime-types": "^2.1.35",
    "axios": "^1.7.2",
    "uuid": "^10.0.0",
    "node-cron": "^3.0.3",
    "qrcode-terminal": "^0.12.0",
    "pino": "^9.3.1",
    "dotenv": "^16.4.5",
    "lru-cache": "^10.4.3",
    "helmet": "^7.1.1",
    "express-rate-limit": "^7.4.0",
    "readline-sync": "^1.4.10",
    "pm2": "^5.4.2",
    "rotating-file-stream": "^5.0.1",
    "pidlockfile": "^2.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10"
  },
  "pm2": {
    "ecosystem": "ecosystem.config.js"
  }
}

